    "bcryptjs": "^2.4.3",
    "date-fns": "^4.0.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.0.0",
    "jsonwebtoken": "^9.0.0",
    "pino": "^9.0.0",
    "prisma": "^6.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0"
  }
}
