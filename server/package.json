{
  "name": "family-ledger-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node src/app/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app/server.js",
    "db:migrate": "npx prisma migrate dev",
